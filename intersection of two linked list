public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        ListNode a=headA;
        ListNode b=headB;
        while(a!=b){

            if(a!=null && b!=null){
                a=a.next;
                b=b.next;
            }
            else if(a==null){
                a=headB;
            }
            else{
                b=headA;
            }
        }
        return a;
    }
}
