class Solution {
    public int addDigits(int num) {
        int c=0;
        int d=0;
        while (num!=0){
            d=num%10;
            c=c+d;
            num=num/10;
        }
        if (c<10){
            return c;
        }
        else{
            return addDigits(c);
        }
    }
}
