class Solution {
    public double findMaxAverage(int[] nums, int k) {
    double maxavg = Double.NEGATIVE_INFINITY;
     for(int i=0;i<=nums.length-k;i++){
        int j=i;
        int count=0;
        int sum=0;
        while(count<k && j<nums.length){
            sum=sum+nums[j];
            count++;
            j++;
        }
        double avg=(double)sum/k;
        maxavg=Math.max(maxavg,avg);
     }
        return maxavg;
        
    }
}
