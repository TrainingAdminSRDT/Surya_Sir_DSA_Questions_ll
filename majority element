class Solution {
    public int majorityElement(int[] nums) {
        int count = 0;
        int r = 0;

        for (int num : nums) {
            if (count == 0) {
                r = num;
                count=count+1;
            }
            else{
              if (num == r) {
                count=count+1;
              } else {
                count=count-1;
              }    
            }
        }

        return r;
    }
}
