class Solution {
    boolean canbeallocated(int[]weights,int days,int mid){
        int count=1;
        int maxweight=0;
        for(int i=0;i<weights.length;i++){
            if(maxweight+weights[i]<=mid){
                maxweight=maxweight+weights[i];
            }
            else{
                maxweight=weights[i];
                count=count+1;
            }
        }
        return (count<=days);

    }
    public int shipWithinDays(int[] weights, int days) {
        int start=Integer.MIN_VALUE;
        int end=0;
        int result=-1;
        for(int i=0;i<weights.length;i++){
            start=Math.max(start,weights[i]);
            end=end+weights[i];
        }

        while(start<=end){
            int mid=start+(end-start)/2;
            if(canbeallocated(weights,days,mid)){
                result=mid;
                end=mid-1;
            }
            else{
                start=mid+1;
            }
        }
        return result;


        
    }
}
