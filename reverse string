class Solution {
    public void reverseString(char[] s) {
        int last=(s.length)-1;
        // while(last>0){
        for (int i=0;i<(s.length)/2;i++){
                char temp=s[i];
                s[i]=s[last];
                s[last]=temp;
                last--;
            }    
        System.out.println(s);    
        // }
        
    }
}
