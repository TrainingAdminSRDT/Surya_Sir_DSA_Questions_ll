class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        int num = 0;  // Position to place the next non-zero element

        for (int i = 0; i < nums.size(); i++) {
            if (nums[i] != 0) {
                swap(nums[num], nums[i]);
                num++;
            }
        }
    }
};