class Solution {
    public void reverseString(char[] s) {
        int j = s.length - 1;
        char temp;
        int i = 0;
        while (j > i) {
            temp = s[i];
            s[i] = s[j];
            s[j] = temp;
            j--;
            i++;
        }
        // temp = s[i];
        // s[i] = s[j];
        // s[j] = temp;

        System.out.println(s);

    }
}
