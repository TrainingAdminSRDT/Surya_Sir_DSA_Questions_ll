class Solution {
    public boolean isSameTree(TreeNode p, TreeNode q) {
        TreeNode left;
        TreeNode right;
        while(p!=null && q!=null){
            if(p.val==q.val){
               return isSameTree(p.left,q.left)&& isSameTree(p.right,q.right);
            }
            else{
                return false;
            }
        }
        if(p == null && q == null){
            return true;
        }
        return false;
    }
}
